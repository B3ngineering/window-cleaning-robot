<?xml version="1.0"?>
<robot name="pulley_system" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Wall dimensions -->
  <xacro:property name="wall_width" value="4.0"/>
  <xacro:property name="wall_height" value="3.0"/>
  <xacro:property name="wall_thickness" value="0.1"/>
  <xacro:property name="pulley_radius" value="0.1"/>
  <xacro:property name="pulley_thickness" value="0.05"/>
  <xacro:property name="mount_size" value="0.15"/>

  <!-- Pulley macro -->
  <xacro:macro name="pulley_assembly" params="name x y z">
    <!-- Mount bracket (fixed to wall) -->
    <link name="${name}_mount">
      <visual>
        <geometry>
          <box size="${mount_size} ${mount_size} ${mount_size}"/>
        </geometry>
        <material name="gray">
          <color rgba="0.5 0.5 0.5 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="${mount_size} ${mount_size} ${mount_size}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
      </inertial>
    </link>

    <joint name="${name}_mount_joint" type="fixed">
      <parent link="wall"/>
      <child link="${name}_mount"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>

    <!-- Pulley wheel -->
    <link name="${name}_pulley">
      <visual>
        <geometry>
          <cylinder radius="${pulley_radius}" length="${pulley_thickness}"/>
        </geometry>
        <material name="blue">
          <color rgba="0.2 0.2 0.8 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${pulley_radius}" length="${pulley_thickness}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.0015"/>
      </inertial>
    </link>

    <!-- Motor joint -->
    <joint name="${name}_motor_joint" type="continuous">
      <parent link="${name}_mount"/>
      <child link="${name}_pulley"/>
      <origin xyz="0 ${mount_size/2 + pulley_thickness/2 + 0.01} 0" rpy="1.5708 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="10.0" velocity="10.0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- Rope attachment point -->
    <link name="${name}_rope_attach">
      <visual>
        <geometry>
          <sphere radius="0.02"/>
        </geometry>
        <material name="red">
          <color rgba="0.8 0.2 0.2 1"/>
        </material>
      </visual>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${name}_rope_joint" type="fixed">
      <parent link="${name}_pulley"/>
      <child link="${name}_rope_attach"/>
      <origin xyz="${pulley_radius} 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Gazebo materials -->
    <gazebo reference="${name}_mount">
      <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="${name}_pulley">
      <material>Gazebo/Blue</material>
    </gazebo>
    <gazebo reference="${name}_rope_attach">
      <material>Gazebo/Red</material>
    </gazebo>
  </xacro:macro>

  <!-- World link for fixed base -->
  <link name="world"/>

  <!-- Base Link (anchor point) -->
  <link name="base_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Wall -->
  <link name="wall">
    <visual>
      <geometry>
        <box size="${wall_width} ${wall_thickness} ${wall_height}"/>
      </geometry>
      <material name="brick">
        <color rgba="0.7 0.4 0.3 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${wall_width} ${wall_thickness} ${wall_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="100.0"/>
      <inertia ixx="100" ixy="0.0" ixz="0.0" iyy="100" iyz="0.0" izz="100"/>
    </inertial>
  </link>

  <joint name="wall_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wall"/>
    <origin xyz="0 0 ${wall_height/2}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="wall">
    <material>Gazebo/Bricks</material>
  </gazebo>

  <!-- Four pulleys at corners -->
  <xacro:pulley_assembly name="top_left" x="${-wall_width/2 + mount_size/2 + 0.1}" y="${wall_thickness/2}" z="${wall_height/2 - mount_size/2 - 0.1}"/>
  <xacro:pulley_assembly name="top_right" x="${wall_width/2 - mount_size/2 - 0.1}" y="${wall_thickness/2}" z="${wall_height/2 - mount_size/2 - 0.1}"/>
  <xacro:pulley_assembly name="bottom_left" x="${-wall_width/2 + mount_size/2 + 0.1}" y="${wall_thickness/2}" z="${-wall_height/2 + mount_size/2 + 0.1}"/>
  <xacro:pulley_assembly name="bottom_right" x="${wall_width/2 - mount_size/2 - 0.1}" y="${wall_thickness/2}" z="${-wall_height/2 + mount_size/2 + 0.1}"/>

  <!-- ROS 2 Control Plugin -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="top_left_motor_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="top_right_motor_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="bottom_left_motor_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="bottom_right_motor_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- Gazebo ROS2 Control Plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find pulley_package)/config/pulley_control.yaml</parameters>
    </plugin>
  </gazebo>

</robot>